# ═══════════════════════════════════════════════════════════════════════════════
#  Social Media Sentiment Intelligence Platform — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=4
API_VERSION=v1

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

ALLOWED_HOSTS=["*"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Database (PostgreSQL + TimescaleDB) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://smsip:smsip_password@localhost:5432/smsip_db
POSTGRES_USER=smsip
POSTGRES_PASSWORD=smsip_password
POSTGRES_DB=smsip_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis Cache ───────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_PASSWORD=redis_password
REDIS_MAX_CONNECTIONS=50
CACHE_TTL_EMBEDDINGS=3600
CACHE_TTL_ANALYSIS=1800

# ── Apache Kafka ──────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_RAW_POSTS=smsip.raw.posts
KAFKA_TOPIC_PROCESSED=smsip.processed.analysis
KAFKA_TOPIC_ALERTS=smsip.alerts.crisis
KAFKA_GROUP_ID=smsip-processors

# ── ML Model Settings ─────────────────────────────────────────────────────────
MODELS_DIR=models
DEVICE=auto                      # auto | cpu | cuda | mps
MODEL_BATCH_SIZE=32
MODEL_MAX_LENGTH=512
ENABLE_MODEL_CACHE=true

# Model paths (HuggingFace IDs or local paths)
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
EMOTION_MODEL=SamLowe/roberta-base-go_emotions
SARCASM_MODEL=helinivan/english-sarcasm-detector
TOXICITY_MODEL=unitary/toxic-bert
FAKE_NEWS_MODEL=hamzab/roberta-fake-news-classification-model
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ── LLM APIs (for executive report generation) ────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Social Media APIs ─────────────────────────────────────────────────────────
# Twitter/X API v2
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# Reddit (PRAW)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SMSIP/1.0 (by /u/your_username)

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# NewsAPI
NEWS_API_KEY=your_newsapi_key

# ── MLflow Experiment Tracking ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=smsip-production

# ── Monitoring & Alerting ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                  # json | console

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ALERT_EMAIL=alerts@yourcompany.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

PAGERDUTY_API_KEY=your_pagerduty_key

# Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin123

# ── Crisis Detection Thresholds ───────────────────────────────────────────────
CRISIS_NEGATIVE_THRESHOLD=0.65   # Trigger at 65%+ negative sentiment
CRISIS_VELOCITY_THRESHOLD=3.0    # 3x normal rate
CRISIS_WINDOW_MINUTES=15
CRISIS_MIN_VOLUME=100

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SARCASM_DETECTION=true
ENABLE_FAKE_NEWS_DETECTION=true
ENABLE_INFLUENCER_ANALYSIS=true
ENABLE_GRAPH_ANALYSIS=true
ENABLE_LLM_REPORTS=true
ENABLE_KAFKA_STREAMING=true

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── AWS (for cloud deployment) ────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=smsip-models-and-reports

# ── Kafka UI ──────────────────────────────────────────────────────────────────
KAFKA_UI_PASSWORD=admin123
