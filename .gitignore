# ═══════════════════════════════════════════════════════════════════════════════
#  SMSIP .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.crt
secrets/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc
*.pyo
*.pyd

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.env/
pyvenv.cfg

# ── ML Models & Weights (large binary files) ──────────────────────────────────
models/sentiment/*/pytorch_model.bin
models/sentiment/*/model.safetensors
models/emotion/*/pytorch_model.bin
models/emotion/*/model.safetensors
models/sarcasm/*/pytorch_model.bin
models/toxicity/*/pytorch_model.bin
models/fake_news/*/pytorch_model.bin
models/forecasting/lstm_sentiment.pt
models/forecasting/prophet_model.pkl
models/forecasting/xgboost_trend.json
models/topic/bertopic_model/
models/network/graphsage_influence/
models/**/*.bin
models/**/*.pt
models/**/*.pkl
models/**/*.ckpt
models/**/*.h5
# Keep config and tokenizer files (small, version-controlled)
!models/**/*.json
!models/**/*.txt
!models/**/*.yaml
!models/**/*.yml

# ── Datasets (large files — use DVC or download scripts) ──────────────────────
datasets/raw/
datasets/processed/
# Keep structure and scripts
!datasets/raw/.gitkeep
!datasets/processed/.gitkeep
!datasets/scripts/

# ── MLflow ────────────────────────────────────────────────────────────────────
mlruns/
mlartifacts/

# ── Reports (generated, not committed) ───────────────────────────────────────
reports/generated/
!reports/generated/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/
junit.xml

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Linting ───────────────────────────────────────────────────────────────────
.ruff_cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
notebooks/**/.ipynb_checkpoints

# ── Node.js / Frontend ────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/
docker/volumes/

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-workspace
*.sublime-project

# ── OS Generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Temporary Files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.orig
*.swp

# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
backups/*.sql
backups/*.dump

# ── Profiling ─────────────────────────────────────────────────────────────────
*.prof
*.lprof
profile_output/

# ── Compiled Assets ───────────────────────────────────────────────────────────
*.pyc
*.pyo
*.pyd
*.so
*.dll
*.dylib

# ── Documentation Build ───────────────────────────────────────────────────────
docs/_build/
docs/site/
site/

# ── Terraform (deployment) ────────────────────────────────────────────────────
deployment/**/.terraform/
deployment/**/terraform.tfstate
deployment/**/terraform.tfstate.backup
deployment/**/*.tfvars
!deployment/**/*.tfvars.example

# ── Kubernetes Secrets ────────────────────────────────────────────────────────
deployment/**/*-secret.yaml
deployment/**/*-secrets.yaml

# ── Cache ─────────────────────────────────────────────────────────────────────
.cache/
__pycache__/
.pytest_cache/
.ruff_cache/
*.cache
